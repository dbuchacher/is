#!/bin/bash
# build — assemble kernel + compile hodos
set -e
cd "$(dirname "$0")"

if [ "$1" = "clean" ]; then
    rm -f code/kernel.bin lang/hodos
    find tests -name '*.bin' -type f -delete 2>/dev/null || true
    find tests -name '*.w.tmp' -type f -delete 2>/dev/null || true
    echo "cleaned"
    exit 0
fi

nasm -f bin code/kernel.asm -o code/kernel.bin

if [ -f lang/hodos.c ]; then
    cc -O3 -Wall -o lang/hodos lang/hodos.c
fi

echo "built: code/kernel.bin"
