#!/bin/bash
# build — assemble kernel flat binary
set -e
cd "$(dirname "$0")"

if [ "$1" = "clean" ]; then
    rm -f kernel.bin hodos
    find tests -name '*.bin' -type f -delete 2>/dev/null || true
    echo "cleaned"
    exit 0
fi

nasm -f bin kernel.asm -o kernel.bin

if [ -f hodos.c ]; then
    cc -O3 -Wall -o hodos hodos.c
fi

echo "built: kernel.bin"
