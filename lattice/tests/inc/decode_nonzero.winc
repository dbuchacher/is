; _decode_nonzero.winc — shared decoder for A2–A5 enumeration tests.
;
; Contract:
;   Input  (reads):  scratch[0]   = outer loop counter, 0..80
;   Output (writes): pipeline     = nonzero_count ∈ {0, 1, 2, 3, 4}
;   Temp used:       scratch[24]  = running accumulator (clobbered)
;                    scratch[28]  = per-axis temp (clobbered)
;
; Decodes `counter` as balanced ternary (a, b, c, d) where:
;     raw_a = counter mod 3               (axis A = WHERE / space)
;     raw_b = (counter / 3) mod 3         (axis B = WHAT  / matter)
;     raw_c = (counter / 9) mod 3         (axis C = WHICH / signal)
;     raw_d = (counter / 27) mod 3        (axis D = WHEN  / time)
;
; Each `raw` is in {0, 1, 2}. Signed coord = raw − 1 ∈ {−1, 0, +1}.
; The "nonzero" indicator per axis is `|raw − 1|` which is:
;     raw = 0 (signed −1)   → |−1| = 1  (nonzero)
;     raw = 1 (signed  0)   → | 0| = 0  (zero)
;     raw = 2 (signed +1)   → |+1| = 1  (nonzero)
; Summing the 4 indicators gives `nonzero_count`.
;
; This file is included with `@include _decode_nonzero.winc` from each
; of atoms_8.w, shell1_80.w, composed_72.w, faces_24.w.

; ── init accumulator ───────────────────────────────
swrite32 θ¹¹ρ  0  24

; ── axis A: raw_a = counter mod 3 ──────────────────
sread32  θ¹ρρ  0
mod      θρ¹ρ  3
sub      θρ¹ρ  1
abs      θρρρ
swrite32 θρ¹ρ  28
sread32  θ¹ρρ  24
sadd32   θ¹ρρ  28
swrite32 θρ¹ρ  24

; ── axis B: raw_b = (counter / 3) mod 3 ────────────
sread32  θ¹ρρ  0
div      θρ¹ρ  3
mod      θρ¹ρ  3
sub      θρ¹ρ  1
abs      θρρρ
swrite32 θρ¹ρ  28
sread32  θ¹ρρ  24
sadd32   θ¹ρρ  28
swrite32 θρ¹ρ  24

; ── axis C: raw_c = (counter / 9) mod 3 ────────────
sread32  θ¹ρρ  0
div      θρ¹ρ  9
mod      θρ¹ρ  3
sub      θρ¹ρ  1
abs      θρρρ
swrite32 θρ¹ρ  28
sread32  θ¹ρρ  24
sadd32   θ¹ρρ  28
swrite32 θρ¹ρ  24

; ── axis D: raw_d = (counter / 27) mod 3 ───────────
sread32  θ¹ρρ  0
div      θρ¹ρ  27
mod      θρ¹ρ  3
sub      θρ¹ρ  1
abs      θρρρ
swrite32 θρ¹ρ  28
sread32  θ¹ρρ  24
sadd32   θ¹ρρ  28
swrite32 θρ¹ρ  24

; ── load final count into pipeline ─────────────────
sread32  θ¹ρρ  24
